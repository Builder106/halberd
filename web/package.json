{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "demo": "bddgen --config playwright.demo.config.ts && playwright test --config playwright.demo.config.ts",
    "test:qa": "playwright test --config playwright.qa.config.ts",
    "test:qa:bdd": "bddgen --config playwright.qa-bdd.config.ts && playwright test --config playwright.qa-bdd.config.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "playwright-bdd": "^9.2.0",
    "tailwindcss": "^4",
    "typescript": "^7",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
